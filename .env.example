# Anthropic API（Studio / タイトルスタジオ）— コピーして .env にリネームし、キーを設定
ANTHROPIC_API_KEY=

# テーマ選定：YouTube（必須・第一指標）
YOUTUBE_DATA_API_KEY=

# 自チャンネル ID（任意。未設定時は @arakiri_ch から解決）
# ARAKIRI_YOUTUBE_CHANNEL_ID=

# モデル設定（任意）
# ANTHROPIC_MODEL_STAGE1=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_STAGE2=claude-opus-4-5
# ANTHROPIC_MODEL_SUMMARY=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_PLANNING=claude-opus-4-5
# ANTHROPIC_MODEL_SCRIPT=claude-opus-4-5
# ANTHROPIC_MODEL_SECTION_CHAT=claude-opus-4-5
# ANTHROPIC_MODEL_THEME_ADAPT=claude-opus-4-5

# テーマ選定：Google 検索（推奨。Programmable Search Engine の CX）
GOOGLE_CSE_CX=
# 任意。未設定時は YOUTUBE_DATA_API_KEY を Google CSE にも使用
# GOOGLE_CSE_API_KEY=

# テーマ選定：X（任意。未設定時は Google site:x.com で代替）
# X_BEARER_TOKEN=

# 任意。個別指定がない機能の共通モデル
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 任意。既定 3300
# PORT=3300

# 限定公開（Vercel 本番など）。未設定なら制限なし
# 単一パスワード（ユーザー名は reviewer）
# SITE_ACCESS_PASSWORD=your-shared-password
# SITE_ACCESS_USER=reviewer

# 複数ユーザー（user:pass をカンマ区切り。設定時は SITE_ACCESS_PASSWORD より優先）
# SITE_ACCESS_CREDENTIALS=tanaka:pass1,suzuki:pass2

# 閲覧専用（レビュアー）ロール：課題提出などの限定共有用
# SITE_ACCESS_CREDENTIALS で発行したユーザー名を指定すると、そのユーザーは
# ・全 API が読み取り専用（保存・削除・AI 生成は 403。競合チャンネル管理のみ例外的に可）
# ・REVIEWER_EPISODE_ALLOWLIST のエピソードだけ閲覧可（未設定なら全て非表示）
# ・作成者名（script_updated_by・履歴の author）はマスク表示
# SITE_ACCESS_REVIEWER_USERS=examiner
# レビュアーに見せるエピソード（outputs/ のフォルダ名をカンマ区切り）
# 99-mrbeast-demo は実データと無関係な閲覧用デモエピソード
# REVIEWER_EPISODE_ALLOWLIST=99-mrbeast-demo

# 台本バージョン管理（Supabase）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub ミラー（任意）: 本番での保存を専用リポジトリへ 1 保存 1 コミットで反映し、
# いつでも過去の版へ戻せるようにする。未設定なら無効（既存挙動のまま）。
# GITHUB_MIRROR_REPO=giraffe-24/scriptstudio-content   # コミット先 owner/repo（ソースとは別の専用リポ推奨）
# GITHUB_MIRROR_TOKEN=ghp_xxx                            # contents:read+write のトークン（省略時は GITHUB_TOKEN を使用）
# GITHUB_MIRROR_BRANCH=main                              # 省略時 main
# GITHUB_MIRROR_EMAIL=scriptstudio@users.noreply.github.com  # コミット author のメール（省略可）
