# Anthropic API（Studio / タイトルスタジオ）— コピーして .env にリネームし、キーを設定
ANTHROPIC_API_KEY=

# テーマ選定：YouTube（必須・第一指標）
YOUTUBE_DATA_API_KEY=

# 自チャンネル ID（任意。未設定時は @arakiri_ch から解決）
# ARAKIRI_YOUTUBE_CHANNEL_ID=

# モデル設定（任意）
# ANTHROPIC_MODEL_STAGE1=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_STAGE2=claude-opus-4-5
# ANTHROPIC_MODEL_SUMMARY=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_PLANNING=claude-opus-4-5
# ANTHROPIC_MODEL_SCRIPT=claude-opus-4-5
# ANTHROPIC_MODEL_SECTION_CHAT=claude-opus-4-5
# ANTHROPIC_MODEL_THEME_ADAPT=claude-opus-4-5

# テーマ選定：Google 検索（推奨。Programmable Search Engine の CX）
GOOGLE_CSE_CX=
# 任意。未設定時は YOUTUBE_DATA_API_KEY を Google CSE にも使用
# GOOGLE_CSE_API_KEY=

# テーマ選定：X（任意。未設定時は Google site:x.com で代替）
# X_BEARER_TOKEN=

# 任意。個別指定がない機能の共通モデル
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 任意。既定 3300
# PORT=3300

# 限定公開（Vercel 本番など）。未設定なら制限なし
# 単一パスワード（ユーザー名は reviewer）
# SITE_ACCESS_PASSWORD=your-shared-password
# SITE_ACCESS_USER=reviewer

# 複数ユーザー（user:pass をカンマ区切り。設定時は SITE_ACCESS_PASSWORD より優先）
# SITE_ACCESS_CREDENTIALS=tanaka:pass1,suzuki:pass2

# 台本バージョン管理（Supabase）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
